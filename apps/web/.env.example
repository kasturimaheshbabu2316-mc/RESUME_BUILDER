# Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# API Base URL (backend endpoint)
# Leave empty for localStorage-only mode (Phase 5)
# Set to your API URL when backend is deployed (Phase 6+)
VITE_API_BASE_URL=

# Example:
# Development: VITE_API_BASE_URL=http://localhost:3000
# Production: VITE_API_BASE_URL=https://api.resume-builder.io
