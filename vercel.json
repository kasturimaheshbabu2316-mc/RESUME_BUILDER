{
  "framework": "vite",
  "buildCommand": "corepack pnpm install && corepack pnpm --filter @resume-builder/types build && corepack pnpm --filter web build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "corepack pnpm install",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "github": {
    "silent": true
  }
}
